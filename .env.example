# ─────────────────────────────────────────────────────────────────────────────
# ChatKroo — Frontend environment variables (Vite)
# Copy this file to `.env` and fill in the value. `.env` is gitignored.
# Only variables prefixed with VITE_ are exposed to the client bundle.
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the backend API + Socket.IO server (no trailing slash).
# Local:      http://localhost:3000
# Production: https://your-backend.onrender.com
VITE_SERVER=http://localhost:3000
